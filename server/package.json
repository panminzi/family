{
  "name": "cartoon-family-server",
  "version": "0.1.0",
  "private": true,
  "description": "卡通家庭后端 - Express + TypeScript + Prisma",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:generate:test": "prisma generate --schema=prisma/schema.test.prisma",
    "prisma:push:test": "prisma db push --schema=prisma/schema.test.prisma --skip-generate",
    "test": "npm run prisma:generate:test && npm run prisma:push:test && vitest run --reporter=verbose"
  },
  "dependencies": {
    "@prisma/client": "6.16.2",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.0",
    "jsonwebtoken": "9.0.2",
    "multer": "2.0.1",
    "node-cron": "3.0.3",
    "openai": "4.67.3",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/multer": "1.4.12",
    "@types/node": "20.16.10",
    "@types/node-cron": "3.0.11",
    "@types/supertest": "6.0.2",
    "prisma": "6.16.2",
    "supertest": "7.0.0",
    "tsx": "4.19.1",
    "typescript": "5.6.2",
    "vitest": "2.1.1"
  }
}
