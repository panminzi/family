# --- 服务端口 ---
PORT=3000

# --- 环境 ---
NODE_ENV=development

# --- JWT ---
JWT_SECRET=please-generate-a-strong-random-secret
JWT_EXPIRES_IN=7d

# --- 数据库（生产建议 Postgres） ---
DATABASE_URL=postgresql://family:family@localhost:5432/family

# --- 上传目录 ---
UPLOADS_DIR=uploads

# --- AI（OpenAI 兼容协议，默认走 10rig 中转站） ---
# 留空 OPENAI_API_KEY 则使用内置 stub（占位画像 + placeholder 头像 + 模板对话），便于本地无外网开发。
# OPENAI_TEXT_MODEL 必须是中转站 /v1/models 列出来的模型；当前 key 只授权了 minimax-m2.7。
# 如果中转站不支持图像生成，generateAvatarUrl 会自动回退到 placehold.co 占位图，无需手工处理。
OPENAI_BASE_URL=https://maas.10rig.com/v1
OPENAI_API_KEY=sk-DE5QP1TncOaHNcjAi9HmTWKJkU14V4a7FcFcR5lJ002aj8og
OPENAI_TEXT_MODEL=minimax-m2.7
OPENAI_IMAGE_MODEL=dall-e-3

# --- 定时任务（cron 表达式） ---
CRON_BREAKFAST=30 7 * * *
CRON_LUNCH=0 12 * * *
CRON_DINNER=30 18 * * *

# 1=启动时拉起 cron；测试与本地默认关闭。
ENABLE_SCHEDULER=0
