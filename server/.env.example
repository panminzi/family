# --- 服务端口 ---
PORT=3000

# --- 环境 ---
NODE_ENV=development

# --- JWT ---
JWT_SECRET=please-generate-a-strong-random-secret
JWT_EXPIRES_IN=7d

# --- 数据库（生产建议 Postgres） ---
DATABASE_URL=postgresql://family:family@localhost:5432/family

# --- 上传目录 ---
UPLOADS_DIR=uploads

# --- OpenAI ---
# 留空则使用内置 stub（占位画像 + placeholder 头像 + 模板对话），便于本地无外网开发。
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=dall-e-3

# --- 定时任务（cron 表达式） ---
CRON_BREAKFAST=30 7 * * *
CRON_LUNCH=0 12 * * *
CRON_DINNER=30 18 * * *

# 1=启动时拉起 cron；测试与本地默认关闭。
ENABLE_SCHEDULER=0
