# Server
APP_NAME=cartoon-family
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=postgresql+psycopg://family:family_pass@localhost:5432/family

# Redis
REDIS_URL=redis://localhost:6379/0

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=20

# AI provider (OpenAI-compatible)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL_TEXT=gpt-4o-mini
AI_MODEL_IMAGE=gpt-image-1

# Meal schedule (24h, local time, comma-separated HH:MM)
MEAL_TIMES=08:00,12:30,18:30
SCHEDULER_TIMEZONE=Asia/Shanghai
